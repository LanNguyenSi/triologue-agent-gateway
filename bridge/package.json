{
  "name": "@triologue/bridge",
  "version": "0.1.0",
  "description": "Local daemon that bridges Triologue @mentions into a headless Claude Code run, with outbound replies routed through the gateway's /byoa/mcp endpoint.",
  "license": "MIT",
  "type": "module",
  "bin": {
    "triologue-bridge": "./dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "examples"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^4.1.4"
  },
  "engines": {
    "node": ">=22"
  },
  "overrides": {
    "postcss": "^8.5.10"
  }
}
