PORT=9500
TRIOLOGUE_URL=http://localhost:4001
GATEWAY_TOKEN=byoa_xxx  # BYOA token for the gateway agent (must be registered in Triologue)
GATEWAY_USERNAME=gateway
AGENTS_CONFIG=./agents.json

# ── agent-tasks → Triologue bridge (optional) ─────────────────────────────
# All three are optional. The /agent-tasks/webhook route returns 503
# feature_disabled until AGENT_TASKS_BOT_TOKEN and AGENT_TASKS_INBOX_ROOM_ID
# are both set. See docs/agent-tasks-bridge.md for the full setup.
AGENT_TASKS_BOT_TOKEN=         # BYOA token for the dedicated "agent-tasks-bot" identity
AGENT_TASKS_INBOX_ROOM_ID=     # Triologue room where signal messages get posted
AGENT_TASKS_WEBHOOK_SECRET=    # Shared HMAC secret matching the project's notificationWebhookSecret (recommended, optional)
AGENT_TASKS_BASE_URL=https://agent-tasks.opentriologue.ai  # used for "open task" deep-links inside the formatted message
